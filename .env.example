# Copy this file to .env and fill in your real credentials.
JWT_SECRET=change_me

# Gmail option. Use a Google App Password, not your regular Gmail password.
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_google_app_password
EMAIL_FROM="FitTrack App <your_email@gmail.com>"

# Alternative SMTP option for SendGrid, Mailgun, or another provider.
# Leave the Gmail variables blank/remove them when using this path.
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# EMAIL_FROM="FitTrack App <verified_sender@example.com>"

ADMIN_EMAILS=admin@example.com
